<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.geonpil.mapper.UserMapper">

    <insert id="insert" parameterType="com.geonpil.domain.User">
        INSERT INTO users (email, password, nickname)
        VALUES (#{email}, #{password}, #{nickname})
    </insert>


    <!-- 이메일 중복 확인 및 로그인 -->
    <select id="findByEmail" parameterType="string" resultType="com.geonpil.domain.User">
        SELECT * FROM users WHERE email = #{email}
    </select>

    <!-- 닉네임 중복 확인 -->
    <select id="findByNickname" parameterType="string" resultType="com.geonpil.domain.User">
        SELECT * FROM users WHERE nickname = #{nickname}
    </select>


    <update id="updatePasswordByEmail">
        UPDATE users
        SET password = #{password}
        WHERE email = #{email}
    </update>


</mapper>