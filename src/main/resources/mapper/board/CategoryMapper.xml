<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.geonpil.mapper.board.CategoryMapper">

    <!-- 카테고리 가져오기 -->
    <select id="getCategoriesByBoardCode"
            parameterType="int"
            resultType="com.geonpil.domain.Category">
        SELECT category_id AS id,
               category_name AS categoryName,
               board_code AS boardCode
        FROM category
        WHERE board_code = #{boardCode}
        ORDER BY category_name
    </select>

    <!-- 카테고리 추가 -->
    <insert id="insertCategory" parameterType="com.geonpil.domain.Category">
        INSERT INTO category (category_name, board_code)
        VALUES (#{categoryName}, #{boardCode})
    </insert>

    <!-- 카테고리 삭제 -->
    <delete id="deleteCategoryById" parameterType="long">
        DELETE FROM category
        WHERE category_id = #{categoryId}
    </delete>

    <!-- 카테고리명 중복 검사 -->
    <select id="existsByNameAndBoardCode" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM category
        WHERE board_code = #{boardCode}
          AND category_name = #{categoryName}
    </select>

    <!-- 카테고리를 사용하는 게시글 수 조회 -->
    <select id="countPostsUsingCategory" parameterType="long" resultType="int">
        SELECT COUNT(*)
        FROM board
        WHERE category_id = #{categoryId}
    </select>

</mapper>