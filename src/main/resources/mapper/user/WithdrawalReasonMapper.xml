<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.geonpil.mapper.withdrawalReason.WithdrawalReasonMapper">


    <insert id="insertWithdrawalReasons" parameterType="com.geonpil.domain.withdrawal.WithdrawalReason">
        INSERT INTO withdrawal_reasons (user_id, reasons, feedback)
        VALUES (#{userId}, #{reasons}, #{feedback})
    </insert>


</mapper>